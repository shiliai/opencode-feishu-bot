# =============================================================================
# OpenCode Feishu Bridge - Environment Configuration
# =============================================================================

# --- OpenCode API Settings ---
OPENCODE_API_BASE_URL=http://localhost:4096
# Optional: API key if OpenCode server requires authentication
# OPENCODE_API_KEY=

# --- Feishu (Lark) App Credentials ---
# Obtain from Feishu Open Platform: https://open.feishu.cn/app
FEISHU_APP_ID=your-app-id
FEISHU_APP_SECRET=your-app-secret
# Optional but recommended for exact @bot matching in group chats
# FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxx

# --- Feishu Connection Options ---
# Use "ws" for WebSocket long connection (recommended for self-hosted)
# Use "webhook" only if you intentionally want ordinary Feishu events delivered via webhook.
# The bridge uses WS for standard bot events, and can still use the HTTP card callback route below.
FEISHU_CONNECTION_TYPE=ws

# --- Card Callback Settings ---
# Optional but recommended for dual-ingress mode.
# When set, the service can verify card callbacks on /webhook/card even while ordinary events use WS.
# FEISHU_CARD_CALLBACK_URL=https://your-domain.com/webhook/card
# FEISHU_CARD_CALLBACK_VERIFICATION_TOKEN=your-verification-token
# Optional: encrypt key for decrypting webhook payloads
# FEISHU_CARD_CALLBACK_ENCRYPT_KEY=

# --- Feishu Event Deduplication ---
# TTL window (ms) for dropping duplicate websocket events or card callback actions.
# FEISHU_EVENT_DEDUP_TTL_MS=300000
# Optional persisted dedup state file for restart-safe duplicate suppression.
# FEISHU_EVENT_DEDUP_PERSIST_PATH=.data/event-dedup.json

# --- Service Port ---
# Port for the HTTP server (card callbacks, health checks)
SERVICE_PORT=3000
# Bind address (0.0.0.0 for all interfaces, 127.0.0.1 for local only)
SERVICE_HOST=0.0.0.0

# --- Throttle Defaults ---
# Minimum interval (ms) between status card updates
# THROTTLE_STATUS_CARD_UPDATE_INTERVAL_MS=2000
# Delay (ms) before retrying a failed status card patch
# THROTTLE_STATUS_CARD_PATCH_RETRY_DELAY_MS=500
# Maximum retry attempts for status card patch
# THROTTLE_STATUS_CARD_PATCH_MAX_ATTEMPTS=3

# --- Control Catalog Cache ---
# TTL (ms) for /model and /agent picker catalog cache (supports stale fallback on refresh errors)
# CONTROL_CATALOG_CACHE_TTL_MS=600000
# Optional OpenCode local model state for favorites/recent ordering enrichment.
# CONTROL_CATALOG_MODEL_STATE_PATH=~/.local/state/opencode/model.json

# --- Logging ---
# Log level: debug, info, warn, error
LOG_LEVEL=info
