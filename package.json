{
  "name": "opencode-feishu-bridge",
  "version": "0.1.0",
  "description": "Feishu (Lark) bot bridge for OpenCode to run and monitor coding tasks from Feishu chat.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && npm start",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.config.ts tests/integration/",
    "test:coverage": "vitest run --coverage",
    "verify:contracts": "tsc --noEmit",
    "smoke:local": "npm run build && npm start"
  },
  "keywords": [
    "opencode",
    "feishu",
    "lark",
    "feishu-bot",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "1.60.0",
    "@opencode-ai/sdk": "^1.1.21",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/deep-eql": "^4.0.2",
    "@types/node": "^25.0.8",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
